@echo off
chcp 65001 >nul
echo --------------------------------------------------------
echo   [Antigravity Master] เตรียมส่งไฟล์โครงการขึ้น GitHub
echo --------------------------------------------------------

:: 1. ตรวจสอบสถานะปัจจุบัน
echo [*] รายการไฟล์ที่มีการเปลี่ยนแปลง:
git status -s
echo.

:: 2. ยอมรับไฟล์ทั้งหมด
echo [*] กำลังรวบรวมไฟล์ทั้งหมด...
git add .

:: 3. ให้ผู้ใช้พิมพ์ประวัติการแก้ไข
set /p commit_msg="[?] พิมพ์รายละเอียดการแก้ไข (เช่น 'เพิ่มข้อมูลใหม่'): "

:: ตรวจสอบว่ามีข้อความไหม ถ้าไม่มีให้ใช้ค่าเริ่มต้น
if "%commit_msg%"=="" (
    set commit_msg="Manual update from local"
)

:: 4. ทำการ Commit
echo [*] กำลังบันทึกประวัติการแก้ไข...
git commit -m "%commit_msg%"

:: 5. ส่งขึ้น GitHub
echo [*] กำลังส่งข้อมูลขึ้น GitHub (main branch)...
git push -u origin main

echo --------------------------------------------------------
echo   อัปโหลดเสร็จสมบูรณ์แล้วครับ!
echo --------------------------------------------------------
pause
